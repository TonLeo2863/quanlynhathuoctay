<Window x:Class="PharmacySalesApp.Views.Purchases.PurchaseView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Phiếu nhập hàng"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        FontSize="14"
        Background="#E5E7EB">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="PHIẾU NHẬP HÀNG"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#111827"
                   Margin="0,0,0,15"/>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="15"
                Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Nhà cung cấp"/>
                    <ComboBox ItemsSource="{Binding Suppliers}"
                              SelectedItem="{Binding SelectedSupplier}"
                              DisplayMemberPath="Name"
                              Height="35"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Thuốc"/>
                    <ComboBox ItemsSource="{Binding Medicines}"
                              SelectedItem="{Binding SelectedMedicine}"
                              DisplayMemberPath="Name"
                              Height="35"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Số lô"/>
                    <TextBox Text="{Binding BatchNumber, UpdateSourceTrigger=PropertyChanged}"
                             Height="35"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,10,0">
                    <TextBlock Text="Hạn sử dụng"/>
                    <DatePicker SelectedDate="{Binding ExpiryDate}"
                                Height="35"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Margin="0,0,10,0">
                    <TextBlock Text="SL / Giá nhập"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                 Height="35"
                                 Margin="0,0,5,0"/>

                        <TextBox Grid.Column="1"
                                 Text="{Binding ImportPrice, UpdateSourceTrigger=PropertyChanged}"
                                 Height="35"
                                 Margin="5,0,0,0"/>
                    </Grid>
                </StackPanel>

                <Button Grid.Column="5"
                        Content="Thêm dòng"
                        Width="110"
                        Height="38"
                        Margin="5,18,0,0"
                        Background="#10B981"
                        Foreground="White"
                        FontWeight="Bold"
                        Command="{Binding AddLineCommand}"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="15">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Chi tiết phiếu nhập"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <DataGrid ItemsSource="{Binding Lines}"
                          SelectedItem="{Binding SelectedLine}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã thuốc" Binding="{Binding MedicineCode}" Width="110"/>
                        <DataGridTextColumn Header="Tên thuốc" Binding="{Binding MedicineName}" Width="*"/>
                        <DataGridTextColumn Header="Số lô" Binding="{Binding BatchNumber}" Width="120"/>
                        <DataGridTextColumn Header="Hạn sử dụng" Binding="{Binding ExpiryDate, StringFormat=dd/MM/yyyy}" Width="130"/>
                        <DataGridTextColumn Header="Số lượng" Binding="{Binding Quantity}" Width="100"/>
                        <DataGridTextColumn Header="Giá nhập" Binding="{Binding ImportPrice, StringFormat=N0}" Width="130"/>
                        <DataGridTextColumn Header="Thành tiền" Binding="{Binding Total, StringFormat=N0}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Row="3"
                Background="White"
                CornerRadius="12"
                Padding="15"
                Margin="0,15,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Ghi chú"/>
                    <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                             Height="55"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom"
                            Margin="15,0,0,0">
                    <TextBlock Text="{Binding TotalAmount, StringFormat=Tổng tiền: {0:N0} đ}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#EF4444"
                               VerticalAlignment="Center"
                               Margin="0,0,20,0"/>

                    <Button Content="Xóa dòng"
                            Width="100"
                            Height="40"
                            Margin="0,0,10,0"
                            Background="#EF4444"
                            Foreground="White"
                            Command="{Binding RemoveLineCommand}"/>

                    <Button Content="Lưu phiếu nhập"
                            Width="140"
                            Height="40"
                            Background="#3B82F6"
                            Foreground="White"
                            FontWeight="Bold"
                            Command="{Binding SaveCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>