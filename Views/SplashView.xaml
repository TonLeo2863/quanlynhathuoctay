<Window x:Class="PharmacySalesApp.Views.SplashView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Khởi động..." Height="300" Width="500"
        WindowStyle="None" WindowStartupLocation="CenterScreen"
        AllowsTransparency="True" Background="Transparent"
        Topmost="True">

    <Border Background="White" CornerRadius="15" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.2" Color="Black"/>
        </Border.Effect>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="💊" FontSize="70" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <TextBlock Text="PHẦN MỀM QUẢN LÝ NHÀ THUỐC" FontSize="22" FontWeight="Bold" Foreground="#3B82F6" HorizontalAlignment="Center"/>
            <TextBlock Text="Phiên bản 1.0" FontSize="14" Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,5,0,0"/>

            <TextBlock Text="Đang khởi động hệ thống..." FontSize="14" FontWeight="SemiBold" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,30,0,0"/>

            <ProgressBar IsIndeterminate="True" Width="200" Height="4" Margin="0,10,0,0" Foreground="#3B82F6" Background="#E5E7EB" BorderThickness="0"/>
        </StackPanel>
    </Border>
</Window>