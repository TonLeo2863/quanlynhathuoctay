<Window x:Class="PharmacySalesApp.Views.Statistics.StatisticsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thống kê doanh thu"
        Height="720"
        Width="1150"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        FontSize="14"
        Background="#E5E7EB">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="THỐNG KÊ DOANH THU"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#111827"
                   Margin="0,0,0,15"/>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="15"
                Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Từ ngày:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <DatePicker SelectedDate="{Binding FromDate}"
                            Width="150"
                            Height="35"
                            Margin="0,0,15,0"/>

                <TextBlock Text="Đến ngày:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <DatePicker SelectedDate="{Binding ToDate}"
                            Width="150"
                            Height="35"
                            Margin="0,0,15,0"/>

                <Button Content="Lọc dữ liệu"
                        Width="110"
                        Height="35"
                        Background="#3B82F6"
                        Foreground="White"
                        FontWeight="Bold"
                        Command="{Binding LoadCommand}"
                        Margin="0,0,10,0"/>

                <Button Content="Report hóa đơn"
                        Width="130"
                        Height="35"
                        Background="#10B981"
                        Foreground="White"
                        FontWeight="Bold"
                        Command="{Binding PrintSimpleReportCommand}"
                        Margin="0,0,10,0"/>

                <Button Content="Report doanh thu"
                        Width="140"
                        Height="35"
                        Background="#8B5CF6"
                        Foreground="White"
                        FontWeight="Bold"
                        Command="{Binding PrintAdvancedReportCommand}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="15"
                Margin="0,0,0,15">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="0,0,0,10">
                    <TextBlock Text="{Binding TotalInvoiceCount, StringFormat=Tổng hóa đơn: {0}}"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,30,0"/>

                    <TextBlock Text="{Binding TotalRevenue, StringFormat=Tổng doanh thu: {0:N0} đ}"
                               FontWeight="Bold"
                               FontSize="16"
                               Foreground="#EF4444"/>
                </StackPanel>

                <DataGrid ItemsSource="{Binding RevenueInvoices}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã hóa đơn" Binding="{Binding InvoiceCode}" Width="150"/>
                        <DataGridTextColumn Header="Ngày bán" Binding="{Binding CreatedDate, StringFormat=dd/MM/yyyy HH:mm}" Width="170"/>
                        <DataGridTextColumn Header="Nhân viên" Binding="{Binding EmployeeName}" Width="170"/>
                        <DataGridTextColumn Header="Khách hàng" Binding="{Binding CustomerName}" Width="170"/>
                        <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TotalAmount, StringFormat=N0}" Width="140"/>
                        <DataGridTextColumn Header="Ghi chú" Binding="{Binding Note}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Row="3"
                Background="White"
                CornerRadius="12"
                Padding="15">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Doanh thu gom nhóm theo ngày"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <DataGrid ItemsSource="{Binding RevenueByDates}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ngày" Binding="{Binding Date, StringFormat=dd/MM/yyyy}" Width="180"/>
                        <DataGridTextColumn Header="Số hóa đơn" Binding="{Binding InvoiceCount}" Width="160"/>
                        <DataGridTextColumn Header="Doanh thu" Binding="{Binding TotalRevenue, StringFormat=N0}" Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</Window>