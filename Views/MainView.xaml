<Window x:Class="PharmacySalesApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Phần mềm bán thuốc"
        Height="650" Width="1100"
        WindowStartupLocation="CenterScreen"
        FontSize="14" FontFamily="Segoe UI"
        Background="#E5E7EB">

    <Window.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style TargetType="Border" x:Key="AppleBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.15" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="#F9FAFB" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <TabControl Margin="10" Background="Transparent" BorderThickness="0">

            <TabItem Header="💊 Quản lý thuốc">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource AppleBox}">
                        <DataGrid ItemsSource="{Binding Medicines}" SelectedItem="{Binding SelectedMedicine}"
                                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" RowHeight="35"
                                  Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tên thuốc" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Đơn vị" Binding="{Binding Unit}" Width="100" />
                                <DataGridTextColumn Header="Giá" Binding="{Binding Price}" Width="120" />
                                <DataGridTextColumn Header="Tồn kho" Binding="{Binding Quantity}" Width="100" />
                            </DataGrid.Columns>
							<DataGrid.RowStyle>
								<Style TargetType="DataGridRow">
									<Style.Triggers>
										<DataTrigger Binding="{Binding IsLowStock}" Value="True">
											<Setter Property="Background" Value="#FFB3B3"/>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</DataGrid.RowStyle>
                        </DataGrid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource AppleBox}">
                        <StackPanel>
                            <TextBlock Text="Thông tin thuốc" FontWeight="Bold" FontSize="18" Margin="0,0,0,15"/>

                            <TextBlock Text="Tên thuốc" Margin="0,5,0,0" Foreground="#4B5563"/>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Đơn vị tính" Margin="0,15,0,0" Foreground="#4B5563"/>
                            <ComboBox ItemsSource="{Binding AvailableUnits}" SelectedItem="{Binding Unit}"/>

                            <TextBlock Text="Giá (VNĐ)" Margin="0,15,0,0" Foreground="#4B5563"/>
                            <TextBox Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Số lượng" Margin="0,15,0,0" Foreground="#4B5563"/>
                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Hình ảnh thuốc" Margin="0,15,0,0" Foreground="#4B5563"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <Border Width="100" Height="100" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Background="#F9FAFB">
                                    <Image Source="{Binding ImagePath}" Stretch="Uniform" Margin="5"/>
                                </Border>

                                <Button Content="Tải ảnh lên" Width="100" Height="36" Margin="15,0,0,0" 
            Background="#6B7280" Command="{Binding SelectImageCommand}"/>
                            </StackPanel>
                            <Grid Margin="0,25,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Thêm" Height="40" Margin="0,0,5,0" Background="#3B82F6" Command="{Binding AddCommand}"/>
                                <Button Grid.Column="1" Content="Sửa" Height="40" Margin="5,0,5,0" Background="#F59E0B" Command="{Binding UpdateCommand}"/>
                                <Button Grid.Column="2" Content="Xóa" Height="40" Margin="5,0,5,0" Background="#EF4444" Command="{Binding DeleteCommand}"/>

                                <Button Grid.Column="3" Content="Nhập Excel" Height="40" Margin="5,0,0,0" Background="#10B981" Command="{Binding ImportExcelCommand}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="🛒 Bán hàng">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource AppleBox}">
                        <DockPanel>
                            <TextBox DockPanel.Dock="Top" Margin="0,0,0,15" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Tìm theo tên thuốc"/>

                            <Button DockPanel.Dock="Bottom" Content="Thêm vào giỏ hàng" Height="45" Margin="0,15,0,0" Background="#10B981" Command="{Binding AddToCartCommand}"/>

                            <DataGrid ItemsSource="{Binding FilteredMedicines}" SelectedItem="{Binding SelectedSellMedicine}"
                                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" RowHeight="35"
                                      Background="Transparent" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tên thuốc" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="Đơn vị" Binding="{Binding Unit}" Width="80" />
                                    <DataGridTextColumn Header="Giá" Binding="{Binding Price}" Width="100" />
                                    <DataGridTextColumn Header="Tồn" Binding="{Binding Quantity}" Width="70" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource AppleBox}">
                        <DockPanel>
                            <TextBlock Text="Giỏ hàng hiện tại" FontSize="18" FontWeight="Bold" DockPanel.Dock="Top" Margin="0,0,0,15"/>

                            <StackPanel DockPanel.Dock="Bottom" Margin="0,15,0,0">
                                <TextBlock Text="Ghi chú (Liều dùng, cách uống...)" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding InvoiceNote, UpdateSourceTrigger=PropertyChanged}" 
             Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="10"/>

                                <TextBlock Text="{Binding TotalAmount, StringFormat=Tổng tiền: {0:N0} đ}" FontSize="20" FontWeight="Bold" Foreground="#EF4444" HorizontalAlignment="Right" Margin="0,15,0,0"/>
                                <Button Content="In Bill &amp; Thanh Toán" Height="45" Margin="0,15,0,0" Background="#3B82F6" Command="{Binding PrintBillCommand}"/>
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding CartItems}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" RowHeight="35" Background="Transparent" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tên thuốc" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="50" />
                                    <DataGridTextColumn Header="Thành tiền" Binding="{Binding TotalPrice}" Width="100" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="🧾 Lịch sử Hóa đơn">
                <Border Style="{StaticResource AppleBox}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Lịch sử các hóa đơn đã xuất" FontWeight="Bold" FontSize="18" Margin="0,0,0,15"/>
                        <DataGrid ItemsSource="{Binding Invoices}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" RowHeight="35" Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã Hóa Đơn" Binding="{Binding InvoiceId}" Width="150" />
                                <DataGridTextColumn Header="Thời gian in" Binding="{Binding CreatedDate, StringFormat='dd/MM/yyyy HH:mm:ss'}" Width="180" />
                                <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TotalAmount, StringFormat={}{0:N0} VNĐ}" Width="150" Foreground="Red" FontWeight="Bold"/>
                                <DataGridTextColumn Header="Ghi chú dược sĩ" Binding="{Binding Note}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </TabItem>

        </TabControl>

        <Popup IsOpen="{Binding IsNotificationVisible}" Placement="Center" AllowsTransparency="True" StaysOpen="True">
            <Border Background="#10B981" CornerRadius="15" Padding="30,15" Margin="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.3"/>
                </Border.Effect>
                <TextBlock Text="{Binding NotificationMessage}" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
            </Border>
        </Popup>
		<Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
      Background="#80000000"
      Panel.ZIndex="999">

			<Border Background="White"
					Width="300"
					Height="150"
					CornerRadius="12"
					HorizontalAlignment="Center"
					VerticalAlignment="Center"
					Padding="20">

				<StackPanel VerticalAlignment="Center">
					<TextBlock Text="Đang import dữ liệu..."
							   FontWeight="Bold"
							   HorizontalAlignment="Center"
							   Margin="0,0,0,15"/>

					<ProgressBar Height="20"
								 Minimum="0"
								 Maximum="100"
								 Value="{Binding ImportProgress}"/>

					<TextBlock Text="{Binding ImportProgress, StringFormat=Tiến trình: {0}%}"
							   HorizontalAlignment="Center"
							   Margin="0,10,0,0"/>
				</StackPanel>
			</Border>
		</Grid>
    </Grid>
</Window>