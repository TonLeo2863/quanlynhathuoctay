<Window x:Class="PharmacySalesApp.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Phần mềm quản lý nhà thuốc"
        Height="720"
        Width="1150"
        WindowStartupLocation="CenterScreen"
        Background="White"
        FontFamily="Segoe UI">

    <Grid Background="White">
        <!-- Vòng trang trí nhẹ -->
        <Ellipse Width="360"
                 Height="360"
                 Fill="#EFF6FF"
                 Opacity="0.8"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Bottom"
                 Margin="-90,0,0,-80"/>

        <Ellipse Width="240"
                 Height="240"
                 Fill="#DBEAFE"
                 Opacity="0.45"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,80,-60,0"/>

        <!-- Card đăng nhập -->
        <Border Width="420"
                Background="White"
                CornerRadius="22"
                Padding="38"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#E5E7EB"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28"
                                  ShadowDepth="4"
                                  Opacity="0.16"
                                  Color="#111827"/>
            </Border.Effect>

            <StackPanel>
                <Border Width="72"
                        Height="72"
                        CornerRadius="36"
                        Background="#EFF6FF"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,18">
                    <TextBlock Text="💊"
                               FontSize="34"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="ĐĂNG NHẬP"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#0F172A"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Vui lòng đăng nhập để tiếp tục sử dụng phần mềm"
                           FontSize="14"
                           Foreground="#64748B"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,28"/>

                <TextBlock Text="Username"
                           Foreground="#334155"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>

                <TextBox x:Name="txtUsername"
                         Height="44"
                         FontSize="15"
                         Padding="12,0"
                         VerticalContentAlignment="Center"
                         BorderBrush="#CBD5E1"
                         BorderThickness="1"
                         Background="#F8FAFC"
                         Margin="0,0,0,18"/>

                <TextBlock Text="Password"
                           Foreground="#334155"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>

                <PasswordBox x:Name="txtPassword"
                             Height="44"
                             FontSize="15"
                             Padding="12,0"
                             VerticalContentAlignment="Center"
                             BorderBrush="#CBD5E1"
                             BorderThickness="1"
                             Background="#F8FAFC"
                             Margin="0,0,0,24"/>

                <Button Content="ĐĂNG NHẬP"
                        Height="46"
                        Background="#2563EB"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Login_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock Text="Phần mềm quản lý nhà thuốc"
                           Foreground="#94A3B8"
                           HorizontalAlignment="Center"
                           Margin="0,26,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>